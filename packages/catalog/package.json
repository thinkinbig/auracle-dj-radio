{
  "name": "@auracle/catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/manifest.js",
  "types": "./dist/manifest.d.ts",
  "exports": {
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "export-catalog": "tsx src/export-catalog.ts",
    "catalog-qc": "tsx src/catalog-qc.ts",
    "test": "tsx --test test/*.test.ts",
    "catalog-normalize": "tsx src/catalog-normalize.ts",
    "catalog-ingest": "tsx src/catalog-ingest.ts"
  },
  "dependencies": {
    "@auracle/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
