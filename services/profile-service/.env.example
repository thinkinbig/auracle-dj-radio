# profile-service — lightweight auth, analytics events, and session feedback derivation
# Copy to .env and fill in. Local .env takes priority over the repo-root .env.
#   cp .env.example .env

# ── Service wiring ──
PROFILE_SERVICE_PORT=3020
# Local default. Production Compose sets PROFILE_EVENTS_STORE=supabase.
PROFILE_EVENTS_STORE=sqlite
PROFILE_EVENTS_DB_PATH=./auracle-events.sqlite
# Required only when PROFILE_EVENTS_STORE=supabase. Never put it in VITE_*.
SUPABASE_SECRET_KEY=
