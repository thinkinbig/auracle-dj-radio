# music-engine — catalog retrieval + tracklist planning
# Copy to .env and fill in. Local .env takes priority over the repo-root .env.
#   cp .env.example .env

# ── Gemini (shared with memory-service; can also be set in repo-root .env) ──
GEMINI_API_KEY=

# ── Flow LLM (Step 2: tracklist planning via structured-output JSON) ──
GEMINI_FLOW_MODEL=gemini-3.1-flash-lite

# ── Service wiring ──
MUSIC_ENGINE_PORT=3010
# Catalog DB path (SQLite — track metadata tags)
MUSIC_ENGINE_DB_PATH=./auracle-catalog.sqlite
# Source of manifest.json + audio/cover/photo assets
CATALOG_DATA_DIR=../../../packages/catalog/data
