{
  "name": "@auracle/music-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "eval:baseline-a": "tsx src/eval/baseline-a.ts",
    "eval:freeze-bc": "tsx src/eval/freeze-bc.ts",
    "eval:metrics": "tsx src/eval/metrics.ts"
  },
  "dependencies": {
    "@auracle/shared": "workspace:*",
    "@google/genai": "^2.8.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}
