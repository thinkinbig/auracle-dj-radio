# Copy to .env and fill in. Auto-loaded at startup (shell exports take priority).
#   cp .env.example .env

# --- Gemini Live ---
GEMINI_API_KEY=your-gemini-api-key-here

# Optional model override (default models/gemini-3.1-flash-live-preview).
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-latest

# Shared secret for orchestrator register/inject (agent-harness must send the
# same value as Authorization: Bearer …). Leave empty for local dev.
# PROXY_REGISTER_SECRET=

# Agent-harness base URL for Lane-1 tool forwarding (optional if set via -harness-url).
# PROXY_HARNESS_URL=http://localhost:3030

# profile-service base URL for Bearer validation via GET /auth/me (optional if set via -auth-url).
# PROXY_AUTH_URL=http://localhost:3020
