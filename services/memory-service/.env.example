# memory-service — stateful session orchestrator + mem0 cross-session memory
# Copy to .env and fill in. Local .env takes priority over the repo-root .env.
#   cp .env.example .env

# ── Gemini (shared key; can also be set in repo-root .env) ──
GEMINI_API_KEY=

# ── Flow LLM (mem0 extraction + re-ranking) ──
GEMINI_FLOW_MODEL=gemini-3.1-flash-lite

# ── mem0 OSS (vector store + history SQLite) ──
# User-preference vectors are separate from catalog structured scoring (ADR-0001).
GEMINI_MEM0_EMBED_MODEL=gemini-embedding-001
QDRANT_URL=http://localhost:6333
AURACLE_MEM0_HISTORY_DB=./mem0-history.db

# ── Service wiring ──
MEMORY_SERVICE_PORT=3020
MEMORY_EVENTS_DB_PATH=./auracle-events.sqlite
MUSIC_ENGINE_URL=http://localhost:3010
# Server-to-proxy registration URL (internal)
PROXY_URL=http://localhost:8080
# Browser-facing proxy base URL (same-origin path avoids CORS in dev)
PROXY_PUBLIC_URL=/proxy
