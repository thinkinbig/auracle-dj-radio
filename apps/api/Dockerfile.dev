# Dev image — no ffmpeg; audio embed clips use pure-JS MP3 frame slicing at seed time.
FROM node:22-alpine

RUN apk add --no-cache python3 make g++ libstdc++
RUN corepack enable pnpm

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/tsconfig.json packages/shared/
COPY apps/api/package.json apps/api/tsconfig.json ./apps/api/

RUN pnpm install --frozen-lockfile

COPY packages/shared/src packages/shared/src
COPY apps/api/src apps/api/src
COPY apps/api/data/tracks apps/api/data/tracks
COPY apps/api/data/catalog apps/api/data/catalog
COPY apps/api/data/covers apps/api/data/covers
COPY apps/api/data/artists apps/api/data/artists

RUN pnpm --filter @auracle/shared build

COPY apps/api/entrypoint-common.sh /entrypoint-common.sh
COPY apps/api/entrypoint.dev.sh /entrypoint.dev.sh
RUN chmod +x /entrypoint-common.sh /entrypoint.dev.sh

EXPOSE 3000
ENTRYPOINT ["/entrypoint.dev.sh"]
