{
  "name": "@auracle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:docker": "tsx watch --include ../../packages/shared/dist src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed": "tsx src/db/seed.ts",
    "generate-tracks": "tsx src/scripts/generate-tracks.ts",
    "generate-covers": "tsx src/scripts/generate-covers.ts",
    "generate-artist-photos": "tsx src/scripts/generate-artist-photos.ts"
  },
  "dependencies": {
    "@auracle/shared": "workspace:*",
    "@fontsource/dejavu-sans": "^5.2.5",
    "@google/genai": "^2.8.0",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "mem0ai": "^3.0.6",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}
