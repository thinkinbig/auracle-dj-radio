# Repo-root .env — shared fallback loaded by all services.
# Service-specific model vars live in each service's own .env.example:
#   services/rt_llm_proxy/.env.example   — GEMINI_MODEL, circuit-breaker flags
#   services/music-engine/.env.example   — GEMINI_FLOW_MODEL, catalog DB path
#   services/memory-service/.env.example — GEMINI_FLOW_MODEL, GEMINI_MEM0_EMBED_MODEL, QDRANT_URL, mem0 paths

# ── Gemini API key (all services read this) ──
GEMINI_API_KEY=
