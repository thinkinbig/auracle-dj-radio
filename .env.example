# Repo-root .env — shared fallback loaded by music-engine, profile-service, agent-harness, catalog CLIs.
# Proxy reads GEMINI_API_KEY (+ optional GEMINI_MODEL) via scripts/dev-stack.sh.
# Per-service ports/paths: services/music-engine/.env.example

# ── Gemini (runtime Brain: Live DJ, Flow) ──
GEMINI_API_KEY=

# ── rt-llm-proxy register/inject auth ──
# Shared secret gating POST /session/{id}/{register,inject}. harness AND proxy
# must read the SAME value (both load this .env via docker-compose.prod.yml).
# Empty = dev mode, no check. PRODUCTION: required — generate `openssl rand -base64 48`,
# set it only in the VM's .env (chmod 600), never commit the real value.
# PROXY_REGISTER_SECRET=
# PROXY_AUTH_URL=http://localhost:3020

GEMINI_FLOW_MODEL=gemini-3.1-flash-lite

# ── Supabase Auth (source of truth for users, email/password, OAuth) ──
# Local dev falls back to the public Auracle Supabase URL when these are blank.
# Set them when pointing the web app and profile-service at another project.
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase Data API (profile-service session_events) ──
# Required for docker-compose.prod.yml (PROFILE_EVENTS_STORE=supabase).
# Generate a server-only secret key in Supabase Dashboard → Settings → API.
# Never expose this in VITE_* variables or browser code; it bypasses RLS.
SUPABASE_SECRET_KEY=

# ── WebRTC deployment ──
# Example values for a same-machine Docker Desktop demo. Choose an available
# inclusive UDP range for your deployment; for LAN use the host's reachable IP.
WEBRTC_PUBLIC_IP=127.0.0.1
WEBRTC_UDP_PORT_MIN=10000
WEBRTC_UDP_PORT_MAX=10100

# ── Azure Blob (catalog media: mp3 / covers / artists) ──
# 由 ops/azure/provision-storage.sh 打印。
BLOB_BASE_URL=
BLOB_HOST=

# Caddy 站点域名(Azure 免费 DNS label,VM 部署时填)
SITE_DOMAIN=auracle-demo.swedencentral.cloudapp.azure.com
