# Repo-root .env — shared fallback loaded by music-engine, profile-service, agent-harness, catalog CLIs.
# Proxy reads GEMINI_API_KEY (+ optional GEMINI_MODEL) via scripts/dev-stack.sh.
# Per-service ports/paths: services/music-engine/.env.example

# ── Gemini (runtime Brain: Live DJ, Flow) ──
GEMINI_API_KEY=

# ── MiniMax (offline catalog: music-2.6 + image-01) ──
MINIMAX_API_KEY=
# Optional: https://api.minimaxi.com for China platform keys
# MINIMAX_API_BASE=https://api.minimax.io

# ── rt-llm-proxy (orchestrator register/inject auth; optional in local dev) ──
# PROXY_REGISTER_SECRET=
# PROXY_AUTH_URL=http://localhost:3020

GEMINI_FLOW_MODEL=gemini-3.1-flash-lite

# ── Supabase Auth (source of truth for users, email/password, OAuth) ──
# Local dev falls back to the public Auracle Supabase URL when these are blank.
# Set them when pointing the web app and profile-service at another project.
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase Data API (profile-service session_events) ──
# Required for docker-compose.prod.yml (PROFILE_EVENTS_STORE=supabase).
# Generate a server-only secret key in Supabase Dashboard → Settings → API.
# Never expose this in VITE_* variables or browser code; it bypasses RLS.
SUPABASE_SECRET_KEY=
