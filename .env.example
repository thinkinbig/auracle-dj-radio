# Repo-root .env — shared fallback loaded by music-engine, memory-service, agent-harness, catalog CLIs.
# Proxy reads GEMINI_API_KEY (+ optional GEMINI_MODEL) via scripts/dev-stack.sh.
# Per-service ports/paths: services/music-engine/.env.example, services/memory-service/.env.example

# ── Gemini (runtime Brain: Live DJ, Flow, mem0) ──
GEMINI_API_KEY=

# ── MiniMax (offline catalog: music-2.6 + image-01) ──
MINIMAX_API_KEY=
# Optional: https://api.minimaxi.com for China platform keys
# MINIMAX_API_BASE=https://api.minimax.io

# ── memory-service (mem0) ──
QDRANT_URL=http://localhost:6333
AURACLE_MEM0_HISTORY_DB=./data/mem0/history.db

# ── shared model overrides (memory-service flow + agent-harness Spotify energy/voicing inference) ──
GEMINI_FLOW_MODEL=gemini-3.1-flash-lite

# ── web: Spotify mixed-queue (ADR-0005) ──
# Spotify app client id + OAuth redirect (PKCE). Requires a Premium account at runtime.
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/spotify/callback
