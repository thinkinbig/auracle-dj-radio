# Gemini (server-side only; browser never talks to Gemini directly)
GEMINI_API_KEY=

# mem0 OSS (self-hosted in apps/api; Qdrant via docker compose dev/prod)
# Local pnpm dev uses localhost paths; Docker Compose overrides QDRANT_URL and DB paths.
QDRANT_URL=http://localhost:6333
AURACLE_MEM0_HISTORY_DB=./data/mem0/history.db

# MiniMax offline music + cover pipeline
MINIMAX_API_KEY=
# MINIMAX_MODEL=music-2.6-free
# MINIMAX_IMAGE_MODEL=image-01
# MINIMAX_API_BASE=https://api.minimax.io
# Covers: MiniMax background (image-01) + sharp typography overlay
# Artist photos: MiniMax press-portrait prompts → data/artists/


# Model split (see doc/auracle_gemini_integration.md §9)
GEMINI_FLOW_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_EMBED_MODEL=gemini-embedding-2
# mem0 stays on text embedding-001 (separate vector index from catalog)
# GEMINI_MEM0_EMBED_MODEL=gemini-embedding-001

# apps/api — local pnpm dev listens here; Docker dev maps container :3000 → host :3001
PORT=3000
AURACLE_DB_PATH=./auracle.sqlite

# Embedder for offline dev/tests without a key: "hash" (deterministic) or "gemini"
# gemini seed embeds audio (first 180s/mp3, pure-JS frame slice — no ffmpeg)
AURACLE_EMBEDDER=hash

# Gemini circuit breaker (rt_llm_proxy modelcb; production Docker defaults ON)
# Local dev: unset = on; set GEMINI_CB_ENABLE=false to disable
GEMINI_CB_ENABLE=true
# GEMINI_CB_OPEN_AFTER=5
# GEMINI_CB_OPEN_FOR_MS=30000
# GEMINI_CB_HALF_OPEN_SUCCESS=3
# GEMINI_CB_AUTH_OPEN_FOR_MS=300000
