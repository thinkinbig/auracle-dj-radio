# Copy to .env.docker for Docker Compose (api service).
# Local `pnpm dev` keeps using repo-root .env — see .env.example.

GEMINI_API_KEY=

GEMINI_FLOW_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_EMBED_MODEL=gemini-embedding-001

GEMINI_CB_ENABLE=true
GEMINI_CB_OPEN_AFTER=5
GEMINI_CB_OPEN_FOR_MS=30000
GEMINI_CB_HALF_OPEN_SUCCESS=3
GEMINI_CB_AUTH_OPEN_FOR_MS=300000

PORT=3000
AURACLE_EMBEDDER=hash

# QDRANT_URL, AURACLE_DB_PATH, AURACLE_MEM0_HISTORY_DB are set in docker-compose.yml.
